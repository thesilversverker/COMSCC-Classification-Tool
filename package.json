{
  "name": "comscc-classification-tool",
  "version": "0.1.0",
  "description": "Repo for webapp to handle COMSCC classification",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --environment jsdom --globals",
    "data:validate": "node scripts/validate-rules-source.mjs",
    "data:nhtsa:plan": "node scripts/run-data-python.mjs data-source/refresh_nhtsa_vehicle_source.py plan",
    "data:nhtsa:bootstrap": "node scripts/run-data-python.mjs data-source/refresh_nhtsa_vehicle_source.py bootstrap",
    "data:nhtsa:update": "node scripts/run-data-python.mjs data-source/refresh_nhtsa_vehicle_source.py update",
    "data:nhtsa:project": "node scripts/run-data-python.mjs data-source/project_open_vehicle.py",
    "data:nhtsa:project:verify": "node scripts/run-data-python.mjs data-source/project_open_vehicle.py --verify",
    "data:nhtsa:project:compare": "node scripts/run-data-python.mjs data-source/project_open_vehicle.py --compare-baseline",
    "data:nhtsa:project:compare:fatal": "node scripts/run-data-python.mjs data-source/project_open_vehicle.py --compare-baseline --compare-baseline-fatal",
    "data:nhtsa:seed-baseline": "node scripts/run-data-python.mjs data-source/seed_baseline_counts.py",
    "data:nhtsa:apply-proposed": "node scripts/run-data-python.mjs data-source/apply_proposed_open_vehicle.py",
    "data:compose-vehicles": "node scripts/compose-vehicles-json.mjs",
    "data:build": "npm run data:compose-vehicles && node scripts/build-rules-bundle.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git@github-thesilversverker:thesilversverker/COMSCC-Classification-Tool.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@sveltejs/adapter-static": "^2.0.3",
    "@sveltejs/kit": "^1.30.4",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.12.12",
    "ajv": "^8.20.0",
    "jsdom": "^22.1.0",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "typescript": "^5.4.5",
    "vite": "^4.5.14",
    "vitest": "^1.6.1",
    "xlsx": "^0.18.5"
  }
}
