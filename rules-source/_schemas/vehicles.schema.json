{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comscc.local/schemas/vehicles.schema.json",
  "title": "Vehicles category source/composed shell",
  "description": "rules-source/vehicles.json: category shell consumed by compose-vehicles-json.mjs and re-emitted with a populated vehicleCatalog. The schema accepts both the empty-shell input and the composed output.",
  "type": "object",
  "required": ["schemaVersion", "category"],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "category": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "const": "vehicles" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "questions": { "type": "array" },
        "vehicleCatalog": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
